# --- Rust workspace (mocida-rs) ---
/mocida-rs/target/
/mocida-rs/Cargo.lock

# --- pre-commit framework ---
# (caches live under the user's home, not the repo, but ignore any local run
#  artifacts just in case)
.pre-commit-cache/

# NOTE: the former root-level C .gitignore content now lives in mocida/.gitignore
# (it moves with the C tree). This root .gitignore only needs the monorepo-wide
# additions above plus whatever the C .gitignore did NOT already cover.

# --- stale build/cache artifacts that may linger at the repo root ---
# (the C build now runs under mocida/; these are leftovers from the old
#  root-level layout or tool caches seeded by setup scripts)
/build/
build-*/
cmake-build-*/
/.webview2/
/vcpkg/
/mimalloc/
mocida_webview.log
mocida_crash_*.log
