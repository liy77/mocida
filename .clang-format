# Calibrated to the existing mocida/src C style so that enforcing on
# changed files only reformats the lines you actually touch.
# Scope: applies to the project's own C in mocida/src. Vendored trees
# (SDL, SDL_image, SDL_ttf) must be excluded via .clang-format-ignore or
# the pre-commit file filter (do NOT place this file where it governs them).
---
Language: Cpp
BasedOnStyle: LLVM

# --- Indentation: 4 spaces, no tabs (observed: 6114 L1 + 2933 L2 four-space
#     lines, zero tab-indented lines across src/uikit/*.c) ---
IndentWidth: 4
TabWidth: 4
UseTab: Never
ContinuationIndentWidth: 4

# --- Braces: attached / K&R (1916 attached vs 14 Allman; 751 attached
#     function-definition braces; "} else" 135 vs else-on-own-line 28) ---
BreakBeforeBraces: Attached

# --- Pointer alignment: left ("UIWidget* p") dominates ~21:1
#     (3328 left vs 161 right). LLVM default is Right, so this is overridden. ---
PointerAlignment: Left
DerivePointerAlignment: false

# --- Column limit: NONE. The codebase freely exceeds 80/100/120
#     (686 lines >80, 110 >100, 69 >120, max 204). Setting 0 disables the
#     limit so clang-format never rewraps existing long lines/comments. ---
ColumnLimit: 0

# --- switch/case: case labels are indented one level under switch ---
IndentCaseLabels: true

# --- Short constructs kept on one line (observed: 1128 "if (...) return;") ---
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortBlocksOnASingleLine: Empty
AllowShortLoopsOnASingleLine: false
AllowShortFunctionsOnASingleLine: None
AllowShortCaseLabelsOnASingleLine: false

# --- Spacing: space after control keywords ("if (", "for (", "switch (");
#     no space before call parens; no space in casts "(Type*)x" ---
SpaceBeforeParens: ControlStatements
SpaceAfterCStyleCast: false
SpacesInParentheses: false
SpacesInCStyleCastParentheses: false

# --- Continuations align under the open paren (e.g. snprintf args) ---
AlignAfterOpenBracket: Align
AlignOperands: true

# --- Trailing comments: align them, matching the struct field doc-comment
#     columns in headers (e.g. UIWidget fields with aligned /**< ... */). ---
AlignTrailingComments: true
ReflowComments: false
SpacesBeforeTrailingComments: 1

# --- Do not reorder #includes: headers are grouped uikit -> SDL -> system
#     deliberately and dependency order matters for the C build. ---
SortIncludes: false
IncludeBlocks: Preserve

# --- Misc to minimize churn ---
KeepEmptyLinesAtTheStartOfBlocks: false
MaxEmptyLinesToKeep: 2
Cpp11BracedListStyle: false
SpaceBeforeAssignmentOperators: true
IndentPPDirectives: None
...
